{
  "system": {
    "db_path": "~/.code_explorer/ce.db",
    "llm": {
      "type": "openai",
      "model": "gpt-4o",
      "base_url": "https://localhost:11434/v1",
      "api_key": ""
    }
  },
  "research": {
    "max_reports_per_codebase": 10
  },
  "codemogger": {
    "inherit_system_llm": false,
    "embedder": {
      "type": "local",
      "model": "all-minilm:l6-v2"
    },
    "languages": [
      "go",
      "rust",
      "python",
      "typescript",
      "javascript"
    ],
    "chunk_lines": 150
  }
}